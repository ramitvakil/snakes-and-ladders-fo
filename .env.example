# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Database (Docker Compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fno_game?schema=public

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Game Engine
VIX_TICK_INTERVAL_MS=5000
VIX_MEAN=18
VIX_MIN=10
VIX_MAX=50

# Demo Mode (set to "true" to enable guest access + auto-bots)
DEMO_MODE=false

# Dev overrides (set to tier name to unlock all features locally)
# Values: Apprentice | MarketWarrior | BillionaireGuild
DEV_TIER_OVERRIDE=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Client (prefix with VITE_) ──────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
