# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Database — SQLite for local dev, PostgreSQL for production
# Local:
DATABASE_URL=file:./dev.db
# Production (set by Render):
# DATABASE_URL=postgresql://user:pass@host:5432/fno_game

# Redis (optional — for multi-instance Socket.IO, leave empty for single instance)
REDIS_URL=

# Auth — CHANGE THIS IN PRODUCTION (use a 64+ char random string)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel domain in production
CORS_ORIGIN=http://localhost:5173

# Game Engine
VIX_TICK_MS=15000

# Demo Mode (set to "true" to enable guest access + auto-bots)
DEMO_MODE=false

# Dev overrides (set to tier name to unlock all features locally)
# Values: Apprentice | MarketWarrior | BillionaireGuild
DEV_TIER_OVERRIDE=

# ─── Client (prefix with VITE_) ──────────────────────
# Local dev — leave empty (Vite proxy handles /api)
VITE_API_URL=
# Production — set to your Render server URL:
# VITE_API_URL=https://snakes-fo-server.onrender.com
# VITE_WS_URL=https://snakes-fo-server.onrender.com
VITE_WS_URL=http://localhost:3001
